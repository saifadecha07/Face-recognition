APP_NAME=face-surveillance
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/face_surveillance
CAMERA_SOURCE=0
CAMERA_NAME=front-door
FRAME_WIDTH=640
FRAME_HEIGHT=480
RECOGNITION_THRESHOLD=85
LOST_FRAMES_THRESHOLD=20
MOTION_DISTANCE_THRESHOLD=18
FACE_DATA_DIR=face_dataset
CASCADE_PATH=haarcascade_frontalface_alt.xml
RUN_CAMERA_ON_STARTUP=false
SHOW_CAMERA_WINDOW=false
